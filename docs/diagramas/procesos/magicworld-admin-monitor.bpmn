      <bpmn2:outgoing>SF_P3_21</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:endEvent id="P3_End_Chatbot" name="Operación chatbot completada">
      <bpmn2:documentation id="documentation_zjtWTA" />
      <bpmn2:incoming>SF_P3_21</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:exclusiveGateway id="P3_GW_MergeModulos" name="Merge módulos">
      <bpmn2:documentation id="documentation_zM8fhQ" />
      <bpmn2:incoming>SF_P3_09_Atrac</bpmn2:incoming>
      <bpmn2:incoming>SF_P3_10_Ticket</bpmn2:incoming>
      <bpmn2:incoming>SF_P3_11_Desc</bpmn2:incoming>
