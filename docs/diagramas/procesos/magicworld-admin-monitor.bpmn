      <bpmn2:documentation id="documentation_dRmr9g" />
      <bpmn2:incoming>SF_P3_22</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="SF_P3_01" sourceRef="P3_Start" targetRef="P3_GW_Canal">
      <bpmn2:documentation id="documentation_Lj37AQ" />
    </bpmn2:sequenceFlow>
