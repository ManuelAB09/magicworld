    <bpmn2:sequenceFlow id="SF_P3_16" sourceRef="P3_EjecutarFuncion" targetRef="P3_GW_Confirmacion">
      <bpmn2:documentation id="documentation_QTGjsQ" />
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SF_P3_17_Si" name="Sí (eliminación)" sourceRef="P3_GW_Confirmacion" targetRef="P3_ConfirmarAccion">
