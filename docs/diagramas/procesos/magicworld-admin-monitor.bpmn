      <bpmn2:outgoing>SF_P3_17_Si</bpmn2:outgoing>
      <bpmn2:outgoing>SF_P3_18_No</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:userTask id="P3_ConfirmarAccion" name="Confirmar acción de eliminación">
      <bpmn2:documentation id="documentation_8wRnsQ" />
      <bpmn2:incoming>SF_P3_17_Si</bpmn2:incoming>
      <bpmn2:outgoing>SF_P3_19</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:exclusiveGateway id="P3_GW_MergeConfirm" name="Merge confirmación">
      <bpmn2:documentation id="documentation_fp5d6A" />
      <bpmn2:incoming>SF_P3_18_No</bpmn2:incoming>
      <bpmn2:incoming>SF_P3_19</bpmn2:incoming>
      <bpmn2:outgoing>SF_P3_20</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:serviceTask id="P3_DevolverResultado" name="Devolver resultado al administrador">
