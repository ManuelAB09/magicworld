    <bpmn2:subProcess id="P3_SP_TiposEntrada" name="Gestión de Tipos de Entrada (CRUD)">
      <bpmn2:documentation id="documentation_kKuAPA" />
      <bpmn2:incoming>SF_P3_05_Ticket</bpmn2:incoming>
      <bpmn2:outgoing>SF_P3_10_Ticket</bpmn2:outgoing>
      <bpmn2:startEvent id="P3_ST_Start" name="Inicio gestión tipos de entrada">
        <bpmn2:outgoing>SF_P3_ST_01</bpmn2:outgoing>
      </bpmn2:startEvent>
      <bpmn2:exclusiveGateway id="P3_ST_GW_Op" name="¿Operación?">
        <bpmn2:incoming>SF_P3_ST_01</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_02_Crear</bpmn2:outgoing>
        <bpmn2:outgoing>SF_P3_ST_03_Editar</bpmn2:outgoing>
        <bpmn2:outgoing>SF_P3_ST_04_Eliminar</bpmn2:outgoing>
      </bpmn2:exclusiveGateway>
      <bpmn2:userTask id="P3_ST_FormCrear" name="Completar formulario de tipo de entrada">
        <bpmn2:incoming>SF_P3_ST_02_Crear</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_05</bpmn2:outgoing>
      </bpmn2:userTask>
      <bpmn2:serviceTask id="P3_ST_ValidarCapacidad" name="Validar capacidad del parque (máx. 500)">
        <bpmn2:incoming>SF_P3_ST_05</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_06</bpmn2:outgoing>
      </bpmn2:serviceTask>
      <bpmn2:serviceTask id="P3_ST_RegistrarTipo" name="Registrar tipo de entrada">
        <bpmn2:incoming>SF_P3_ST_06</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_07</bpmn2:outgoing>
      </bpmn2:serviceTask>
      <bpmn2:userTask id="P3_ST_SeleccionarEditar" name="Seleccionar y modificar tipo de entrada">
        <bpmn2:incoming>SF_P3_ST_03_Editar</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_08</bpmn2:outgoing>
      </bpmn2:userTask>
      <bpmn2:serviceTask id="P3_ST_RevalidarCapacidad" name="Revalidar capacidad y actualizar tipo">
        <bpmn2:incoming>SF_P3_ST_08</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_09</bpmn2:outgoing>
      </bpmn2:serviceTask>
      <bpmn2:serviceTask id="P3_ST_VerificarDescuentos" name="Verificar no hay descuentos asociados">
        <bpmn2:incoming>SF_P3_ST_04_Eliminar</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_10</bpmn2:outgoing>
      </bpmn2:serviceTask>
      <bpmn2:serviceTask id="P3_ST_EliminarTipo" name="Eliminar tipo de entrada">
        <bpmn2:incoming>SF_P3_ST_10</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_11</bpmn2:outgoing>
      </bpmn2:serviceTask>
      <bpmn2:exclusiveGateway id="P3_ST_GW_Merge" name="Merge operaciones">
        <bpmn2:incoming>SF_P3_ST_07</bpmn2:incoming>
        <bpmn2:incoming>SF_P3_ST_09</bpmn2:incoming>
        <bpmn2:incoming>SF_P3_ST_11</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_12</bpmn2:outgoing>
      </bpmn2:exclusiveGateway>
      <bpmn2:serviceTask id="P3_ST_NotificarWebSocket" name="Notificar cambio por WebSocket a compra de entradas">
        <bpmn2:incoming>SF_P3_ST_12</bpmn2:incoming>
        <bpmn2:outgoing>SF_P3_ST_13</bpmn2:outgoing>
      </bpmn2:serviceTask>
      <bpmn2:endEvent id="P3_ST_End" name="Tipo de entrada gestionado">
        <bpmn2:incoming>SF_P3_ST_13</bpmn2:incoming>
      </bpmn2:endEvent>
      <bpmn2:sequenceFlow id="SF_P3_ST_01" sourceRef="P3_ST_Start" targetRef="P3_ST_GW_Op" />
      <bpmn2:sequenceFlow id="SF_P3_ST_02_Crear" name="Crear" sourceRef="P3_ST_GW_Op" targetRef="P3_ST_FormCrear" />
      <bpmn2:sequenceFlow id="SF_P3_ST_03_Editar" name="Editar" sourceRef="P3_ST_GW_Op" targetRef="P3_ST_SeleccionarEditar" />
      <bpmn2:sequenceFlow id="SF_P3_ST_04_Eliminar" name="Eliminar" sourceRef="P3_ST_GW_Op" targetRef="P3_ST_VerificarDescuentos" />
      <bpmn2:sequenceFlow id="SF_P3_ST_05" sourceRef="P3_ST_FormCrear" targetRef="P3_ST_ValidarCapacidad" />
      <bpmn2:sequenceFlow id="SF_P3_ST_06" sourceRef="P3_ST_ValidarCapacidad" targetRef="P3_ST_RegistrarTipo" />
      <bpmn2:sequenceFlow id="SF_P3_ST_07" sourceRef="P3_ST_RegistrarTipo" targetRef="P3_ST_GW_Merge" />
      <bpmn2:sequenceFlow id="SF_P3_ST_08" sourceRef="P3_ST_SeleccionarEditar" targetRef="P3_ST_RevalidarCapacidad" />
      <bpmn2:sequenceFlow id="SF_P3_ST_09" sourceRef="P3_ST_RevalidarCapacidad" targetRef="P3_ST_GW_Merge" />
      <bpmn2:sequenceFlow id="SF_P3_ST_10" sourceRef="P3_ST_VerificarDescuentos" targetRef="P3_ST_EliminarTipo" />
      <bpmn2:sequenceFlow id="SF_P3_ST_11" sourceRef="P3_ST_EliminarTipo" targetRef="P3_ST_GW_Merge" />
      <bpmn2:sequenceFlow id="SF_P3_ST_12" sourceRef="P3_ST_GW_Merge" targetRef="P3_ST_NotificarWebSocket" />
      <bpmn2:sequenceFlow id="SF_P3_ST_13" sourceRef="P3_ST_NotificarWebSocket" targetRef="P3_ST_End" />
    </bpmn2:subProcess>
    <bpmn2:subProcess id="P3_SP_Atracciones" name="Gestión de Atracciones (CRUD)">
      <bpmn2:documentation id="documentation_YXFPKA" />
