<?xml version="1.0"?>
<ruleset name="MagicWorld - Unused Code"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Detecta paquetes, importaciones y variables no utilizadas en el código Java.
    </description>

    <!-- Variables locales sin utilizar -->
    <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>

    <!-- Campos privados sin utilizar -->
    <rule ref="category/java/bestpractices.xml/UnusedPrivateField"/>

    <!-- Parámetros de métodos privados no utilizados -->
    <rule ref="category/java/bestpractices.xml/UnusedFormalParameter">
        <properties>
            <!-- Ignorar parámetros en métodos que sobreescriben (override) -->
            <property name="checkAll" value="false"/>
        </properties>
    </rule>

    <!-- Asignaciones a variables que nunca se leen -->
    <rule ref="category/java/bestpractices.xml/UnusedAssignment"/>

    <!-- Métodos privados sin utilizar -->
    <rule ref="category/java/bestpractices.xml/UnusedPrivateMethod"/>

</ruleset>

